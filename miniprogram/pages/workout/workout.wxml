<navigation-bar title="训练记录" back="{{false}}" />

<scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="page-scroll">
  <!-- 日期选择器 -->
  <view class="date-bar">
    <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange">
      <view class="date-picker">
        <text class="date-text">{{displayDate}}</text>
        <text class="date-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 训练列表 -->
  <view wx:if="{{exercises.length > 0}}" class="exercise-list">
    <view class="list-header">
      <text class="list-count">{{exercises.length}} 个动作 · {{totalSets}} 组</text>
      <text class="clear-btn" bindtap="onClearAll">清空</text>
    </view>
    <view wx:for="{{exercises}}" wx:key="id" class="card exercise-card">
      <view class="exercise-header">
        <text class="exercise-name">{{item.name || '未命名动作'}}</text>
        <view class="exercise-actions">
          <text class="action-btn" bindtap="onEditExercise" data-index="{{index}}">编辑</text>
          <text class="action-btn danger" bindtap="onDeleteExercise" data-index="{{index}}">删除</text>
        </view>
      </view>
      <view class="exercise-detail">
        <text class="detail-text">{{item.sets}} 组 × {{item.reps}} 次</text>
        <text wx:if="{{item.weight > 0}}" class="detail-text">@ {{item.weight}} kg</text>
      </view>
      <text wx:if="{{item.note}}" class="exercise-note">{{item.note}}</text>
    </view>

    <!-- 保存为模板 -->
    <view class="save-tpl-btn" bindtap="onSaveAsTemplate">
      <text>+ 保存为自定义模板</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state" style="padding: 60rpx 0 30rpx;">
    <text>暂无训练记录</text>
    <text style="font-size: 24rpx; margin-top: 8rpx;">点击下方按钮添加训练动作</text>
  </view>

  <!-- 训练模板 -->
  <view class="section-title">训练模板</view>
  <view class="template-list">
    <view wx:for="{{allTemplates}}" wx:key="key" class="card template-card" bindtap="onLoadTemplate" data-key="{{item.key}}">
      <view class="template-header">
        <text class="template-name">{{item.name}}</text>
        <view class="template-right">
          <text wx:if="{{item.isCustom}}" class="template-badge">自定义</text>
          <text wx:if="{{item.isCustom}}" class="template-del" catchtap="onDeleteTemplate" data-key="{{item.key}}">✕</text>
          <text class="template-arrow">→</text>
        </view>
      </view>
      <text class="template-desc">{{item.description}}</text>
      <view class="template-exercises">
        <text wx:for="{{item.exercises}}" wx:for-item="ex" wx:key="name" class="template-ex-tag">{{ex.name}}</text>
      </view>
    </view>
  </view>

  <view style="height: 120rpx;"></view>
</scroll-view>

<!-- FAB 添加按钮 -->
<view class="fab" bindtap="onAddExercise">+</view>

<!-- 编辑弹窗 -->
<exercise-editor
  wx:if="{{showEditor}}"
  exercise="{{currentExercise}}"
  isNew="{{isNewExercise}}"
  bind:save="onSaveExercise"
  bind:cancel="onCloseEditor"
/>

<!-- 模板选择弹窗 -->
<template-picker
  wx:if="{{showPicker}}"
  templateName="{{pickerName}}"
  templateDesc="{{pickerDesc}}"
  exercises="{{pickerExercises}}"
  bind:confirm="onPickerConfirm"
  bind:cancel="onPickerCancel"
/>

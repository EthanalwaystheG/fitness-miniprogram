<view class="mask" bindtap="onCancel"></view>
<view class="editor-panel">
  <view class="editor-header">
    <text class="editor-title">{{isNew ? '添加动作' : '编辑动作'}}</text>
    <text class="editor-close" bindtap="onCancel">取消</text>
  </view>

  <scroll-view scroll-y class="editor-body">
    <!-- 动作库选择 -->
    <view class="preset-section">
      <text class="section-label">从动作库选择（可选）</text>
      <view class="form-row-2">
        <view class="form-group flex-1">
          <text class="form-label">部位</text>
          <picker value="{{groupIndex}}" range="{{groupLabels}}" bindchange="onGroupChange">
            <view class="form-input center picker">{{groupLabels[groupIndex]}}</view>
          </picker>
        </view>
        <view class="form-group flex-1">
          <text class="form-label">动作</text>
          <picker value="{{exerciseIndex}}" range="{{exerciseNames}}" bindchange="onExerciseSelect">
            <view class="form-input center picker">{{exerciseNames[exerciseIndex] || '请选择'}}</view>
          </picker>
        </view>
      </view>
    </view>

    <view class="divider"></view>

    <view class="form-group">
      <text class="form-label">动作名称</text>
      <input class="form-input" value="{{name}}" bindinput="onNameInput" placeholder="例如：杠铃卧推" />
    </view>

    <view class="form-row-3">
      <view class="form-group flex-1">
        <text class="form-label">组数</text>
        <input class="form-input center" type="digit" value="{{sets}}" bindinput="onSetsInput" />
      </view>
      <view class="form-group flex-1">
        <text class="form-label">次数</text>
        <input class="form-input center" type="digit" value="{{reps}}" bindinput="onRepsInput" />
      </view>
      <view class="form-group flex-1">
        <text class="form-label">重量 (kg)</text>
        <input class="form-input center" type="digit" value="{{weight}}" bindinput="onWeightInput" />
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">备注</text>
      <input class="form-input" value="{{note}}" bindinput="onNoteInput" placeholder="可选备注" />
    </view>
  </scroll-view>

  <view class="editor-footer">
    <button class="btn-confirm" bindtap="onSave">保存</button>
  </view>
</view>
